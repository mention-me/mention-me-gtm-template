scenarios:
- name: Product tag injects expected URL with price and customer extras
  code: |-
    const mockData = {
      tagType: 'product',
      partnerCode: 'TEST123',
      locale: 'en_GB',
      product_id: 'PROD-1',
      product_sku: 'SKU-1',
      product_name: 'Blue Widget',
      product_price: '29.99',
      prod_email: 'regina@example.com',
      prod_segment: 'men'
    };
    mock('injectScript', (url, onSuccess) => {
      assertThat(url).contains('https://tag.mention-me.com/api/v2/product/TEST123');
      assertThat(url).contains('situation=product');
      assertThat(url).contains('implementation=sharelink');
      assertThat(url).contains('product_id=PROD-1');
      assertThat(url).contains('product_name=Blue%20Widget');
      assertThat(url).contains('product_price=29.99');
      assertThat(url).contains('email=regina%40example.com');
      assertThat(url).contains('segment=men');
      onSuccess();
    });
    runCode(mockData);
    assertApi('gtmOnSuccess').wasCalled();

