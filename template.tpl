const injectScript = require('injectScript');
const queryPermission = require('queryPermission');
const encodeUriComponent = require('encodeUriComponent');
const logToConsole = require('logToConsole');

const PATHS = {
  product: 'product',
  checkout: 'refereefind',
  postpurchase: 'referreroffer',
  landing: 'referreroffer'
};

const SITUATIONS = {
  product: 'product',
  checkout: 'checkout',
  postpurchase: 'postpurchase',
  landing: 'landingpage'
};

const HOSTS = {
  live: 'tag.mention-me.com',
  test: 'tag-demo.mention-me.com'
};

const tagType = data.tagType;
const path = PATHS[tagType];
const defaultSituation = SITUATIONS[tagType];
const situation = (tagType === 'checkout' && data.chk_situation) ? data.chk_situation : defaultSituation;
const host = HOSTS[data.environment] || HOSTS.live;

if (!path) {
  logToConsole('Mention Me: unknown tag type', tagType);
  data.gtmOnFailure();
} else {
  const baseUrl = 'https://' + host + '/api/v2/' + path + '/' + encodeUriComponent(data.partnerCode);
  const params = [
    'situation=' + encodeUriComponent(situation),
    'locale=' + encodeUriComponent(data.locale || 'en_GB')
  ];

  const append = (name, value) => {
    if (value !== undefined && value !== null && value !== '') {
      params.push(name + '=' + encodeUriComponent(value));
    }
  };

  if (tagType === 'product') {
    params.push('implementation=sharelink');
    append('product_id', data.product_id);
    append('product_sku', data.product_sku);
    append('product_name', data.product_name);
    append('product_price', data.product_price);
    append('firstname', data.prod_firstname);
    append('surname', data.prod_surname);
    append('fullname', data.prod_fullname);
    append('email', data.prod_email);
    append('customer_id', data.prod_customer_id);
    append('phone_number', data.prod_phone_number);
    append('segment', data.prod_segment);
  } else if (tagType === 'checkout') {
    append('firstname', data.chk_firstname);
    append('surname', data.chk_surname);
    append('fullname', data.chk_fullname);
    append('email', data.chk_email);
    append('customer_id', data.chk_customer_id);
    append('phone_number', data.chk_phone_number);
    append('segment', data.chk_segment);
    append('call_to_action_url', data.chk_call_to_action_url);
    append('implementation', data.chk_implementation);
  } else if (tagType === 'landing') {
    append('title', data.lnd_title);
    append('firstname', data.lnd_firstname);
    append('surname', data.lnd_surname);
    append('fullname', data.lnd_fullname);
    append('email', data.lnd_email);
    append('customer_id', data.lnd_customer_id);
    append('username', data.lnd_username);
    append('phone_number', data.lnd_phone_number);
    append('segment', data.lnd_segment);
    append('custom_field', data.lnd_custom_field);
    append('custom_share_field', data.lnd_custom_share_field);
    append('call_to_action_url', data.lnd_call_to_action_url);
    append('implementation', data.lnd_implementation);
  } else if (tagType === 'postpurchase') {
    append('firstname', data.firstname);
    append('surname', data.surname);
    append('email', data.email);
    append('fullname', data.fullname);
    append('title', data.title);
    append('username', data.username);
    append('phone_number', data.phone_number);
    append('segment', data.segment);
    append('order_number', data.order_number);
    append('order_subtotal', data.order_subtotal);
    append('order_currency', data.order_currency);
    params.push('coupon_code=' + encodeUriComponent(data.coupon_code || ''));
    append('customer_id', data.customer_id);
    append('order_discount_amount', data.order_discount_amount);
    append('order_item_count', data.order_item_count);
    append('order_is_subscription', data.order_is_subscription);
    append('order_is_gift', data.order_is_gift);
    append('order_date', data.order_date);
    append('address_line1', data.address_line1);
    append('address_line2', data.address_line2);
    append('address_city', data.address_city);
    append('address_county', data.address_county);
    append('address_postcode', data.address_postcode);
    append('address_country', data.address_country);
    append('product_ids', data.product_ids);
    append('product_skus', data.product_skus);
    append('product_names', data.product_names);
    append('product_prices', data.product_prices);
    append('product_quantities', data.product_quantities);
    append('custom_field', data.custom_field);
    append('custom_share_field', data.custom_share_field);
    append('mm_encrypted', data.mm_encrypted);
    append('implementation', data.implementation);
    append('variation', data.variation);
  }

  const url = baseUrl + '?' + params.join('&');

  if (queryPermission('inject_script', url)) {
    injectScript(url, data.gtmOnSuccess, data.gtmOnFailure, url);
  } else {
    logToConsole('Mention Me: inject_script permission denied for', url);
    data.gtmOnFailure();
  }
}


